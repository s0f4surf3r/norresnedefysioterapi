<!DOCTYPE html>
<html lang="da">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}Nørre Snede Fysioterapi</title>
  <meta name="description" content="{{ description or 'Fysioterapi, osteopati og træning i Nørre Snede. Siden 1989.' }}">
  <meta property="og:title" content="{% if title %}{{ title }} — {% endif %}Nørre Snede Fysioterapi">
  <meta property="og:description" content="{{ description or 'Fysioterapi, osteopati og træning i Nørre Snede. Siden 1989.' }}">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Nørre Snede Fysioterapi">
  <meta property="og:locale" content="da_DK">
  <meta property="og:image" content="https://norresnedefysioterapi.dk/images/team-foto.jpg">
  <meta property="og:image:width" content="1408">
  <meta property="og:image:height" content="768">
  <link rel="icon" href="/images/favicon.ico">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="{{ bodyClass or '' }}">

  <header class="site-header">
    <a href="/" class="site-name">
      <img src="/images/logo.svg" alt="" class="site-logo" width="36" height="36">
      <span>Nørre Snede Fysioterapi</span>
    </a>
    <nav class="site-nav">
      <a href="/" {% if page.url == '/' %}class="active"{% endif %}>Forside</a>
      <a href="/behandlinger/" {% if '/behandlinger' in page.url %}class="active"{% endif %}>Behandlinger</a>
      <a href="/traening/" {% if '/traening' in page.url %}class="active"{% endif %}>Træning & Hold</a>
      <a href="/klinikken/" {% if '/klinikken' in page.url %}class="active"{% endif %}>Klinikken</a>
      <a href="/firma/" {% if '/firma' in page.url %}class="active"{% endif %}>Firmafysioterapi</a>
      <a href="/priser/" {% if '/priser' in page.url %}class="active"{% endif %}>Priser</a>
    </nav>
    <a href="/kontakt/" class="header-cta">Book en tid</a>
    <button class="menu-toggle" aria-label="Åbn menu" onclick="document.body.classList.toggle('menu-open')">
      <span></span><span></span><span></span>
    </button>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div>
        <span class="footer-brand">Nørre Snede Fysioterapi</span>
        <p class="footer-tagline">Bevægelse er medicin.<br>Siden 1989 hjælper vi i Nørre Snede og omegn.</p>
        <p style="font-size:14px;color:rgba(246,244,240,0.5);">Engholmvej 9 · 8766 Nørre Snede<br>
        <a href="tel:+4575770161" style="color:rgba(246,244,240,0.65)">+45 75 77 01 61</a> ·
        <a href="mailto:info@nsfys.dk" style="color:rgba(246,244,240,0.65)">info@nsfys.dk</a></p>
      </div>
      <div class="footer-col">
        <h4>Klinikken</h4>
        <a href="/behandlinger/">Behandlinger</a>
        <a href="/traening/">Træning & Hold</a>
        <a href="/klinikken/">Vores team</a>
        <a href="/firma/">Firmafysioterapi</a>
        <a href="/priser/">Priser</a>
      </div>
      <div class="footer-col">
        <h4>Telefontider</h4>
        <p>Man–tir: 08.00–16.30</p>
        <p>Ons: 08.00–14.00</p>
        <p>Tor: 08.00–15.30</p>
        <p>Fre: 08.00–13.30</p>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 Nørre Snede Fysioterapi</p>
      <div style="display:flex;gap:24px">
        <a href="/kontakt/">Kontakt</a>
        <a href="/persondatapolitik/">Persondatapolitik</a>
      </div>
    </div>
  </footer>

</body>
</html>
